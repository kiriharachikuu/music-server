# ============ 数据库（SQLite，零配置）============
# SQLite 为文件式数据库，无需安装服务端，数据库文件将自动创建在指定路径
DATABASE_URL="file:./dev.db"

# ============ 服务端口 ============
PORT=3000

# ============ JWT 配置 ============
JWT_SECRET="请替换为强随机字符串"
JWT_EXPIRES="7d"

# ============ 跨域白名单（多个用逗号分隔）============
# 本地开发 + 生产域名（用户端 + 管理后台）
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,https://xtmusic.chikuu.top,https://xtmusicadmin.chikuu.top"

# ============ 存储驱动：local | s3 ============
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH="./uploads"

# ============ S3 / 对象存储配置 ============
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION=""
S3_PUBLIC_DOMAIN=""

# ============ 数据库（PostgreSQL 15+）============
# 格式：postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xt_music?schema=public"

# ============ 服务端口 ============
PORT=3000

# ============ JWT 配置 ============
JWT_SECRET="请替换为强随机字符串"
JWT_EXPIRES="7d"

# ============ 跨域白名单（多个用逗号分隔）============
CORS_ORIGINS="http://localhost:3001,http://localhost:3002"

# ============ 存储驱动：local | s3 ============
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH="./uploads"

# ============ S3 / 对象存储配置 ============
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION=""
S3_PUBLIC_DOMAIN=""

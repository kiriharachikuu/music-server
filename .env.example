# ============ 运行环境 ============
# development | production | test
NODE_ENV=development

# ============ 数据库（SQLite，零配置）============
# SQLite 为文件式数据库，无需安装服务端，数据库文件将自动创建在指定路径
# 生产环境建议放在持久化数据目录，如 ./data/prod.db
DATABASE_URL="file:./dev.db"

# ============ 服务端口 ============
PORT=3000

# ============ JWT 配置 ============
# ⚠️  生产环境必须替换为强随机字符串（至少32位）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="请替换为强随机字符串"
JWT_EXPIRES="7d"

# ============ 跨域白名单（多个用逗号分隔）============
# 本地开发 + 生产域名（用户端 + 管理后台）
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,https://xtmusic.chikuu.top,https://xtmusicadmin.chikuu.top"

# ============ 存储驱动：local | s3 ============
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH="./uploads"

# ============ S3 / 对象存储配置 ============
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION=""
S3_PUBLIC_DOMAIN=""

# ============ 安全与代理配置（Nginx 反代场景）============
# 是否启用 Helmet 安全头（Nginx 已配置安全头时可设为 false，避免重复）
HELMET_ENABLED=true

# 是否启用 HSTS（Nginx 已配置 HSTS 时可设为 false）
HSTS_ENABLED=true

# 是否启用后端 CORS（Nginx 层处理 CORS 时可设为 false，避免重复）
CORS_ENABLED=true

# 是否信任代理（Nginx 反代场景必须设为 true，确保获取真实客户端 IP 和协议）
TRUST_PROXY=false

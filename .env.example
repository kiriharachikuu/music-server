# ============ 运行环境 ============
NODE_ENV=development

# ============ 数据库（SQLite，零配置）============
DATABASE_URL="file:./dev.db"

# ============ 服务端口 ============
PORT=3000

# ============ JWT 配置 ============
JWT_SECRET="请替换为强随机字符串"
JWT_EXPIRES="7d"

# ============ 跨域白名单（多个用逗号分隔）============
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# ============ 存储驱动：local | s3 | cos ============
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH="./uploads"

# ============ 对象存储配置（S3 / COS 通用，与参考 config-v1.js 简洁风格一致）============
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_SECRET_ID=""
STORAGE_SECRET_KEY=""
STORAGE_SESSION_TOKEN=""

# ============ S3 兼容服务可选配置（MinIO / R2 等，COS 可留空）============
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_DOMAIN=""

# ============ 安全与代理配置 ============
HELMET_ENABLED=true
HSTS_ENABLED=true
CORS_ENABLED=true
TRUST_PROXY=true

# ============ 文件上传大小限制（单位：MB）============
UPLOAD_MAX_SIZE_IMAGE_MB=10
UPLOAD_MAX_SIZE_AUDIO_MB=200
UPLOAD_MAX_SIZE_LYRIC_MB=5

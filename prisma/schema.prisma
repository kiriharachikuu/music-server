// XingTone后端 - Prisma 数据模型
// 数据库：SQLite（文件式，零配置，易于上手）
// 文档：https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户角色
enum Role {
  USER
  ADMIN
  EDITOR
}

// 歌曲发布状态
enum SongStatus {
  PUBLISHED
  DRAFT
}

// Banner 显示状态
enum BannerStatus {
  VISIBLE
  HIDDEN
}

// 用户表
model User {
  id        String    @id @default(cuid())
  username  String    @unique
  email     String    @unique
  password  String
  avatar    String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  /** 最近登录时间 */
  lastLoginAt DateTime?
  /** 累计登录次数 */
  loginCount   Int     @default(0)
  /** 密码最近更新时间，用于校验 JWT 是否在密码修改前签发（旧 token 自动失效） */
  passwordUpdatedAt DateTime?

  playlists       Playlist[]
  favorites       Favorite[]
  albumFavorites  AlbumFavorite[]
  playlistFavorites PlaylistFavorite[]
  playHistories   PlayHistory[]
  downloadRecords DownloadRecord[]
  operationLogs   OperationLog[]
  sessionFavorites LiveSessionFavorite[]
  clipFavorites   LiveClipFavorite[]

  @@index([deletedAt])
}

// 歌曲表
model Song {
  id          String     @id @default(cuid())
  title       String
  artist      String
  albumId     String?
  album       Album?     @relation(fields: [albumId], references: [id], onDelete: SetNull)
  duration    Int
  fileUrl     String
  coverUrl    String?
  lyricUrl    String?
  /** 歌词正文（LRC 文本），优先于 lyricUrl 文件读取 */
  lyricContent String?
  releaseDate DateTime
  plays       Int        @default(0)
  /** 收藏数，收藏时 +1 / 取消时 -1 */
  favoriteCount Int      @default(0)
  status      SongStatus @default(PUBLISHED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  playlistSongs   PlaylistSong[]
  songTags        SongTag[]
  songArtists     SongArtist[]
  favorites       Favorite[]
  playHistories   PlayHistory[]
  downloadRecords DownloadRecord[]
  banners         Banner[]

  @@index([albumId])
  @@index([plays])
  @@index([releaseDate])
  @@index([status])
  @@index([deletedAt])
  @@index([title])
  @@index([artist])
}

// 专辑表
model Album {
  id          String    @id @default(cuid())
  name        String
  artist      String
  cover       String?
  description String?
  releaseDate DateTime
  songCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  songs         Song[]
  albumArtists  AlbumArtist[]
  albumFavorites AlbumFavorite[]

  @@index([deletedAt])
  @@index([name])
  @@index([artist])
}

// 歌单表
model Playlist {
  id          String    @id @default(cuid())
  name        String
  cover       String?
  description String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic    Boolean   @default(true)
  /** 系统歌单标记：官方运营歌单 */
  isSystem    Boolean   @default(false)
  playCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  playlistSongs PlaylistSong[]
  playlistFavorites PlaylistFavorite[]

  @@index([userId])
  @@index([isPublic])
  @@index([deletedAt])
  @@index([name])
}

// 歌单-歌曲关联表
model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  sort       Int
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, sort])
}

// 首页 Banner 表
model Banner {
  id        String       @id @default(cuid())
  title     String
  imageUrl  String
  /** 点击跳转内部路径（优先级最低） */
  linkUrl   String?
  /** 关联歌曲 ID：点击优先播放该歌曲（优先级最高） */
  songId    String?
  /** 广告外链：点击打开新窗口（优先级中） */
  adUrl     String?
  sort      Int          @default(0)
  status    BannerStatus @default(VISIBLE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  song Song? @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@index([sort, status])
}

// 操作日志表（管理后台写操作审计）
model OperationLog {
  id         String   @id @default(cuid())
  userId     String?
  /** 冗余存储用户名，避免用户被删后无法追溯 */
  username   String?
  /** 操作类型：CREATE_SONG / UPDATE_SONG / DELETE_SONG / CREATE_BANNER 等 */
  action     String
  /** 资源类型：song / album / playlist / banner / user 等 */
  resource   String?
  resourceId String?
  /** 操作详情（描述或 JSON 字符串） */
  detail     String?
  ip         String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// 标签表
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  songTags SongTag[]
}

// 歌曲-标签关联表
model SongTag {
  id     String @id @default(cuid())
  songId String
  tagId  String

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([songId, tagId])
  @@index([tagId])
}

// 收藏表（歌曲收藏）
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@index([userId])
}

// 专辑收藏表
model AlbumFavorite {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([userId, albumId])
  @@index([userId])
}

// 歌单收藏表
model PlaylistFavorite {
  id         String   @id @default(cuid())
  userId     String
  playlistId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([userId, playlistId])
  @@index([userId])
}

// 播放历史表
model PlayHistory {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  playTime  DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([userId, playTime])
}

// 下载记录表
model DownloadRecord {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 系统设置表
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// App版本更新表
model AppVersion {
  id            String   @id @default(cuid())
  versionCode   Int      @unique
  versionName   String
  title         String?
  content       String?  // 更新内容，JSON数组字符串
  downloadUrl   String
  fileSize      Int      // 字节
  md5           String?
  forceUpdate   Boolean  @default(false)
  minVersionCode Int     @default(0)
  channel       String   @default("stable") // stable / beta
  platform      String   @default("android") // android / ios / desktop
  status        String   @default("published") // draft / published / deprecated
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([channel, platform, status])
  @@index([versionCode])
}

// 歌手表
model Artist {
  id                 String        @id @default(cuid())
  name               String        @unique
  avatar             String?
  bio                String?
  representativeWorks String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  songArtists        SongArtist[]
  albumArtists       AlbumArtist[]

  @@index([name])
  @@index([deletedAt])
}

// 歌曲-歌手关联表（多对多）
model SongArtist {
  id        String   @id @default(cuid())
  songId    String
  artistId  String
  sort      Int      @default(0)
  createdAt DateTime @default(now())

  song    Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([songId, artistId])
  @@index([songId])
  @@index([artistId])
}

// 专辑-歌手关联表（多对多）
model AlbumArtist {
  id        String   @id @default(cuid())
  albumId   String
  artistId  String
  sort      Int      @default(0)
  createdAt DateTime @default(now())

  album   Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([albumId, artistId])
  @@index([albumId])
  @@index([artistId])
}

// 搜索日志表（用于热门搜索词统计，按时间窗口聚合）
// 不建立 User 外键关联，仅作为日志使用，定期清理
model SearchLog {
  id        String   @id @default(cuid())
  keyword   String
  ip        String?
  createdAt DateTime @default(now())

  @@index([keyword])
  @@index([createdAt])
  @@index([ip, createdAt])
}

// ============ 直播歌切功能 ============

// 直播场次合集表
model LiveSession {
  id            String     @id @default(cuid())
  title         String
  artist        String
  cover         String?
  description   String?
  liveTime      DateTime
  sessionNumber Int?
  songCount     Int        @default(0)
  status        SongStatus @default(DRAFT)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  clips           LiveClip[]
  sessionFavorites LiveSessionFavorite[]

  @@index([liveTime])
  @@index([status])
  @@index([deletedAt])
  @@index([title])
  @@index([artist])
}

// 直播歌切表（每首歌在一次直播中的单独表演记录）
model LiveClip {
  id           String     @id @default(cuid())
  title        String
  artist       String
  sessionId    String
  trackIndex   Int
  duration     Int
  fileUrl      String
  coverUrl     String?
  lyricContent String?
  status       SongStatus @default(DRAFT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  session   LiveSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  favorites LiveClipFavorite[]

  @@index([sessionId])
  @@index([sessionId, trackIndex])
  @@index([title])
  @@index([artist])
  @@index([status])
}

// 直播场次收藏表
model LiveSessionFavorite {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([userId])
}

// 直播歌切收藏表
model LiveClipFavorite {
  id        String   @id @default(cuid())
  userId    String
  clipId    String
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clip LiveClip  @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@unique([userId, clipId])
  @@index([userId])
}
